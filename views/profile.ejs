<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title><%= profileUser.fullName %> - Profile</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-4">
      <div class="bg-white rounded-4 shadow-sm p-4 mb-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center gap-3">
          <img
            src="<%= profileUser.profileImageURL %>"
            alt="<%= profileUser.fullName %>"
            class="rounded-circle"
            width="100"
            height="100"
            style="object-fit: cover"
            onerror="this.onerror=null; this.src='/images/default.png';"
          />
          <div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <h1 class="h3 mb-0"><%= profileUser.fullName %></h1>
              <span class="badge text-bg-primary"><%= profileUser.role %></span>
            </div>
            <div class="text-secondary mt-2">
              Member since
              <%= profileUser.createdAt ? new Date(profileUser.createdAt).toLocaleDateString("en-IN", { year: "numeric", month: "long", day: "numeric" }) : "Unknown" %>
            </div>
            <div class="fw-semibold mt-1"><%= blogs.length %> blog<%= blogs.length === 1 ? "" : "s" %></div>
          </div>
        </div>
      </div>

      <h2 class="h4 mb-3">Blogs by <%= profileUser.fullName %></h2>

      <% if (blogs.length > 0) { %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        <% blogs.forEach(blog => { %>
        <%
          const plainBody = (blog.body || "").replace(/<[^>]*>/g, "");
          const bodyPreview = plainBody.length > 100 ? `${plainBody.slice(0, 100)}...` : plainBody;
          const createdAt = blog.createdAt
            ? new Date(blog.createdAt).toLocaleDateString("en-IN", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })
            : "";
        %>
        <div class="col">
          <div class="card h-100">
            <img
              src="<%= blog.coverImageURL %>"
              class="card-img-top"
              alt="<%= blog.title %>"
              onerror="this.onerror=null; this.src='/images/default.png';"
            />
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= blog.title %></h5>
              <p class="card-text text-muted"><%= bodyPreview %></p>
              <div class="small text-secondary mt-auto mb-3"><%= createdAt %></div>
              <a href="/blog/<%= blog._id %>" class="btn btn-primary">View</a>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="alert alert-info" role="alert">
        <%= profileUser.fullName %> has not published any blogs yet.
      </div>
      <% } %>
    </div>

    <%- include('./partials/scripts') %>
  </body>
</html>