<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <style>
      .blog-content {
        font-size: 1.1rem;
        line-height: 1.8;
      }

      .blog-content blockquote {
        border-left: 4px solid #0d6efd;
        color: #495057;
        margin: 1.5rem 0;
        padding: 0.75rem 1rem;
        background: #ffffff;
        border-radius: 0 8px 8px 0;
      }

      .blog-content pre,
      .blog-content code {
        background: #212529;
        color: #f8f9fa;
        border-radius: 8px;
      }

      .blog-content pre {
        padding: 1rem;
        overflow-x: auto;
      }

      .blog-content img {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
      }
    </style>
    <title>Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-4">
      <h1><%= blog.title %></h1>
      <% if (locals.user && blog.createdBy && blog.createdBy._id.toString() === locals.user._id) { %>
      <div class="d-flex gap-2 mb-3">
        <a href="/blog/edit/<%= blog._id %>" class="btn btn-warning btn-sm">Edit</a>
        <form action="/blog/delete/<%= blog._id %>" method="post">
          <button
            type="submit"
            class="btn btn-danger btn-sm"
            onclick="return confirm('Are you sure you want to delete this blog?')"
          >
            Delete
          </button>
        </form>
      </div>
      <% } %>
      <img
        src="<%= blog.coverImageURL %>"
        width="700px"
        class="img-fluid rounded-4"
        onerror="this.onerror=null; this.src='/images/default.png';"
      />
      <div class="mt-3">
        <button
          id="summaryBtn"
          class="btn btn-outline-primary btn-sm"
          onclick="generateSummary()"
        >
          ✨ Generate AI Summary
        </button>
      </div>
      <div id="summaryContainer" class="card mt-3 d-none">
        <div class="card-body">
          <div class="fw-semibold mb-2">🤖 AI Summary</div>
          <p id="summaryText" class="mb-0"></p>
        </div>
      </div>
      <div class="blog-content mt-3"><%- blog.body %></div>
    </div>

    <div class="container mt-4">
      <a
        href="/user/profile/<%= blog.createdBy._id %>"
        class="d-inline-flex align-items-center gap-2 text-decoration-none text-dark"
      >
        <img
          src="<%= blog.createdBy.profileImageURL %>"
          width="50px"
          class="rounded-circle"
          onerror="this.onerror=null; this.src='/images/default.png';"
        />
        <%= blog.createdBy.fullName %>
      </a>
    </div>

    <div class="container mt-3">
      <h1>Comments (<%= comments.length %>)</h1>
      <% if (locals.user) { %>
      <form action="/blog/comment/<%= blog._id %>" method="post">
        <div class="mb-3">
          <input
            type="text"
            name="content"
            class="form-control"
            placeholder="Enter your comment"
          />
          <button class="btn btn-sm btn-primary" type="submit">Add</button>
        </div>
      </form>

      <% } %>
      <div class="mt-3">
        <% comments.forEach(comment => { %>
        <div>
          <img src="<%= comment.createdBy.profileImageURL %>" width="50px" />
          <%= comment.createdBy.fullName %>
          <pre><%= comment.content %></pre>
        </div>
        <% }) %>
      </div>
    </div>

    <%- include('./partials/scripts') %>
    <script>
      async function generateSummary() {
        const button = document.querySelector("#summaryBtn");
        const summaryContainer = document.querySelector("#summaryContainer");
        const summaryText = document.querySelector("#summaryText");

        button.disabled = true;
        button.textContent = "⏳ Generating...";
        summaryContainer.classList.remove("d-none");
        summaryText.textContent = "Generating summary...";

        try {
          const response = await fetch("/blog/summary/<%= blog._id %>");
          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.error || "Failed to generate summary");
          }

          summaryText.textContent = data.summary;
          button.textContent = "✅ Summary Generated";
        } catch (error) {
          summaryText.textContent = "Unable to generate a summary right now. Please try again.";
          button.textContent = "❌ Failed — Try Again";
          button.disabled = false;
        }
      }
    </script>
  </body>
</html>
