<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <link
      href="https://cdn.quilljs.com/1.3.7/quill.snow.css"
      rel="stylesheet"
    />
    <title>Edit Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container editor-form-container mt-3">
      <form id="blogForm" action="/blog/edit/<%= blog._id %>" method="post" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="coverImage" class="form-label">Cover Image</label>
          <% if (blog.coverImageURL) { %>
          <div class="mb-2">
            <img src="<%= blog.coverImageURL %>" alt="Current cover image" class="img-fluid" style="max-width: 300px" />
          </div>
          <% } %>
          <input
            type="file"
            class="form-control"
            id="coverImage"
            name="coverImage"
            aria-describedby="coverImage"
          />
        </div>
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            type="text"
            class="form-control"
            id="title"
            name="title"
            aria-describedby="title"
            value="<%= blog.title %>"
          />
        </div>
        <div class="mb-3">
          <label for="body">Body</label>
          <input type="hidden" name="body" id="hiddenBody" />
          <div id="editor" style="height: 300px"></div>
        </div>
        <div class="mb-3">
          <button class="btn btn-primary">Update</button>
          <a href="/blog/<%= blog._id %>" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>

    <%- include('./partials/scripts') %>
    <script src="https://cdn.quilljs.com/1.3.7/quill.js"></script>
    <script>
      const quill = new Quill("#editor", {
        theme: "snow",
        modules: {
          toolbar: [
            [{ header: [1, 2, 3, false] }],
            ["bold", "italic", "underline", "strike"],
            [{ list: "ordered" }, { list: "bullet" }],
            ["blockquote", "code-block"],
            ["link", "image"],
            ["clean"],
          ],
        },
      });

      quill.root.innerHTML = <%- JSON.stringify(blog.body || "").replace(/</g, "\\u003c") %>;

      document.querySelector("#blogForm").addEventListener("submit", function () {
        document.querySelector("#hiddenBody").value = quill.root.innerHTML;
      });
    </script>
  </body>
</html>